  "components": {
    "schemas": {
      "Body_post_ingest_upload_api_v1_ingest_upload_post": {
        "properties": {
          "files": {
            "items": {
              "type": "string",
              "contentMediaType": "application/octet-stream"
            },
            "type": "array",
            "title": "Files",
            "description": "One or more .txt / .md / .pdf / .docx files"
          },
          "chat_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Chat Id",
            "description": "Conversation id for metadata scoping"
          }
        },
        "type": "object",
        "required": [
          "files"
        ],
        "title": "Body_post_ingest_upload_api_v1_ingest_upload_post"
      },
      "ChatMessage": {
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user",
              "assistant"
            ],
            "title": "Role"
          },
          "content": {
            "type": "string",
            "title": "Content"
          }
        },
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "title": "ChatMessage"
      },
      "ChatRequest": {
        "properties": {
          "message": {
            "type": "string",
            "minLength": 1,
            "title": "Message",
            "description": "本輪使用者問題（或一鍵審閱預設句）"
          },
          "top_k": {
            "type": "integer",
            "maximum": 20.0,
            "minimum": 1.0,
            "title": "Top K",
            "default": 5
          },
          "history": {
            "items": {
              "$ref": "#/components/schemas/ChatMessage"
            },
            "type": "array",
            "title": "History"
          },
          "strict": {
            "type": "boolean",
            "title": "Strict",
            "description": "True 時等同側欄「嚴格只根據知識庫回答」；False 時走完整路由",
            "default": false
          },
          "chat_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Chat Id"
          },
          "rag_scope_chat_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Rag Scope Chat Id",
            "description": "若設定，檢索僅限該對話上傳之 chunks（對齊「只搜尋此對話上傳的檔案」）"
          },
          "original_question": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Original Question"
          },
          "clarification_reply": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Clarification Reply"
          },
          "chart_confirmation_question": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Chart Confirmation Question"
          },
          "chart_confirmation_reply": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Chart Confirmation Reply"
          }
        },
        "type": "object",
        "required": [
          "message"
        ],
        "title": "ChatRequest",
        "description": "對齊 `streamlit_app` 呼叫 `answer_with_rag_and_log` 時所帶參數。"
      },
      "ChatResponse": {
        "properties": {
          "answer": {
            "type": "string",
            "title": "Answer"
          },
          "sources": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Sources"
          },
          "chunks": {
            "items": {
              "$ref": "#/components/schemas/ChunkItem"
            },
            "type": "array",
            "title": "Chunks"
          },
          "tool_name": {
            "type": "string",
            "title": "Tool Name"
          },
          "extra": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Extra"
          },
          "latency_sec": {
            "type": "number",
            "title": "Latency Sec",
            "description": "本次呼叫耗時（秒），供觀測用"
          },
          "next_original_question_for_clarification": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Next Original Question For Clarification",
            "description": "當 tool_name 為 ask_web_vs_rag 時，下一輪請帶入 original_question"
          },
          "next_chart_confirmation_question": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Next Chart Confirmation Question",
            "description": "當本輪詢問是否產圖時，下一輪請帶入 chart_confirmation_question"
          }
        },
        "type": "object",
        "required": [
          "answer",
          "sources",
          "chunks",
          "tool_name",
          "latency_sec"
        ],
        "title": "ChatResponse"
      },
      "ChunkItem": {
        "properties": {
          "tag": {
            "type": "string",
            "title": "Tag",
            "default": ""
          },
          "text": {
            "type": "string",
            "title": "Text",
            "default": ""
          }
        },
        "additionalProperties": true,
        "type": "object",
        "title": "ChunkItem",
        "description": "檢索片段；與 rag 流程 `chunks` 一致，允許額外欄位。"
      },
      "DockerContainerInfo": {
        "properties": {
          "container_id": {
            "type": "string",
            "title": "Container Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "image": {
            "type": "string",
            "title": "Image"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "state": {
            "type": "string",
            "title": "State"
          }
        },
        "type": "object",
        "required": [
          "container_id",
          "name",
          "image",
          "status",
          "state"
        ],
        "title": "DockerContainerInfo"
      },
      "DockerContainersResponse": {
        "properties": {
          "engine_available": {
            "type": "boolean",
            "title": "Engine Available"
          },
          "containers": {
            "items": {
              "$ref": "#/components/schemas/DockerContainerInfo"
            },
            "type": "array",
            "title": "Containers"
          },
          "error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error"
          }
        },
        "type": "object",
        "required": [
          "engine_available"
        ],
        "title": "DockerContainersResponse"
      },
      "EvalBatchDetailResponse": {
        "properties": {
          "run_id": {
            "type": "string",
            "title": "Run Id"
          },
          "metrics": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Metrics"
          },
          "results": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Results",
            "description": "run_*_results.jsonl 每行一筆原始 JSON"
          }
        },
        "type": "object",
        "required": [
          "run_id"
        ],
        "title": "EvalBatchDetailResponse",
        "description": "GET /api/v1/eval/batch/{run_id}"
      },
      "EvalBatchListResponse": {
        "properties": {
          "run_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Run Ids"
          },
          "runs_dir": {
            "type": "string",
            "title": "Runs Dir",
            "description": "解析後之批次結果目錄（供除錯／說明）"
          }
        },
        "type": "object",
        "required": [
          "runs_dir"
        ],
        "title": "EvalBatchListResponse",
        "description": "GET /api/v1/eval/batch/runs"
      },
      "EvalConfigResponse": {
        "properties": {
          "eval_log_enabled": {
            "type": "boolean",
            "title": "Eval Log Enabled"
          }
        },
        "type": "object",
        "required": [
          "eval_log_enabled"
        ],
        "title": "EvalConfigResponse",
        "description": "GET /api/v1/eval/config"
      },
      "EvalRunEntry": {
        "properties": {
          "timestamp": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Timestamp"
          },
          "question": {
            "type": "string",
            "title": "Question",
            "default": ""
          },
          "answer": {
            "type": "string",
            "title": "Answer",
            "default": ""
          },
          "tool_name": {
            "type": "string",
            "title": "Tool Name",
            "default": ""
          },
          "latency_sec": {
            "type": "number",
            "title": "Latency Sec",
            "default": 0.0
          },
          "top_k": {
            "type": "integer",
            "title": "Top K",
            "default": 0
          },
          "source_count": {
            "type": "integer",
            "title": "Source Count",
            "default": 0
          },
          "chat_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Chat Id"
          }
        },
        "type": "object",
        "title": "EvalRunEntry",
        "description": "單筆線上運行記錄（eval_runs.jsonl 一行）。"
      },
      "EvalRunsResponse": {
        "properties": {
          "entries": {
            "items": {
              "$ref": "#/components/schemas/EvalRunEntry"
            },
            "type": "array",
            "title": "Entries"
          },
          "eval_log_enabled": {
            "type": "boolean",
            "title": "Eval Log Enabled",
            "description": "是否啟用寫入 EVAL_LOG（與 eval_log.is_enabled() 一致）；不影響讀取既有檔案。"
          },
          "limit": {
