{
  "name": "agent-demo-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:all",
    "build:check": "vue-tsc --noEmit -p tsconfig.app.json",
    "build:frontend": "vite build --mode frontend --outDir dist-frontend",
    "build:admin": "vite build --mode admin --outDir dist-admin",
    "build:all": "npm run build:check && npm run build:frontend && npm run build:admin",
    "preview": "vite preview",
    "preview:frontend": "vite preview --outDir dist-frontend",
    "preview:admin": "vite preview --outDir dist-admin",
    "openapi:export": "cd .. && uv run python scripts/export_openapi.py",
    "openapi:gen": "openapi-typescript ../contracts/openapi.json -o src/types/openapi.generated.ts",
    "openapi:sync": "npm run openapi:export && npm run openapi:gen",
    "contract:check": "npm run openapi:gen && vue-tsc --noEmit -p tsconfig.app.json",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "echarts": "^6.0.0",
    "marked": "^18.0.0",
    "pinia": "^3.0.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "~5.7.2",
    "vite": "^6.0.7",
    "vue-tsc": "^2.2.0"
  }
}
