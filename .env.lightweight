# ============================================================
# Contract Compliance Agent — 輕量化部署設定檔
# 適用場景：資源受限環境（筆電 / 低顯存 GPU / 邊緣部署）
#
# 設計原則：「輕任務 4B 量化模型，生成任務 12B，零依賴雲端 LLM」
# 與 .env.example（標準部署）的差異請見 README.md 輕量化部署章節
# ============================================================

# --- Pinecone（不變）---
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=weck06

# --- LLM Provider：全本地，無雲端 API 依賴 ---
CHAT_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_API_KEY=ollama
OLLAMA_TIMEOUT_SEC=180

# 預設聊天模型（fallback，若階段未設定時使用）
OLLAMA_CHAT_MODEL=gemma3:12b

# --- 階段化模型分配（輕量化核心）---
# 低成本推論階段：使用 4B 量化（QAT, ~2.5 GB VRAM）
OLLAMA_ROUTER_MODEL=gemma3:4b-it-qat
OLLAMA_RAG_REWRITE_MODEL=gemma3:4b-it-qat
OLLAMA_RAG_RERANK_MODEL=gemma3:4b-it-qat
OLLAMA_RAG_PACKAGE_MODEL=gemma3:4b-it-qat
OLLAMA_SMALL_TALK_MODEL=gemma3:4b-it-qat

# 高品質生成階段：使用 12B（~7 GB VRAM）
OLLAMA_RAG_GENERATE_MODEL=gemma3:12b
OLLAMA_RESEARCH_GENERATE_MODEL=gemma3:12b
OLLAMA_ANALYSIS_MODEL=gemma3:12b
OLLAMA_CONTRACT_RISK_GENERATE_MODEL=gemma3:12b

# 合約高品質覆核（選填，需要更大記憶體）
# OLLAMA_CONTRACT_RISK_VERIFY_MODEL=gpt-oss:120b

# --- Timeout（輕量模型推論較快，縮短等待）---
OLLAMA_ROUTER_TIMEOUT_SEC=15
OLLAMA_RAG_REWRITE_TIMEOUT_SEC=15
OLLAMA_RAG_RERANK_TIMEOUT_SEC=20
OLLAMA_RAG_PACKAGE_TIMEOUT_SEC=30
OLLAMA_RAG_GENERATE_TIMEOUT_SEC=90
OLLAMA_CONTRACT_RISK_GENERATE_TIMEOUT_SEC=90

# --- Embedding：本地模型（零雲端費用）---
EMBEDDING_PROVIDER=ollama
# 選項 1（預設）：snowflake-arctic-embed2:568m — 輕量快速，英文為主，~0.5 GB VRAM
OLLAMA_EMBED_MODEL=snowflake-arctic-embed2:568m
# 選項 2：bge-m3 — 多語言 SOTA（繁中/英/日），1024-dim，~1.5 GB VRAM
#   切換步驟：(1) ollama pull bge-m3  (2) 取消下方註解、把上方設定註解掉
# OLLAMA_EMBED_MODEL=bge-m3
# 注意：切換 embedding 模型後，若 Pinecone index 維度不同需重建 index 並重新 ingest

# --- 網路搜尋（仍需 API key，但屬選填功能）---
TAVILY_API_KEY=your_tavily_api_key

# --- RAG 輕量化調整 ---
TOP_K=3                         # 標準是 5，降低以減少 context 長度
RAG_USE_HISTORY_FOR_QUERY=1
RAG_MAX_HISTORY_TURNS=6         # 標準是 12，縮小記憶窗口

# Hybrid 檢索（BM25 為本地計算，建議保留）
RAG_USE_BM25=1
RAG_BM25_TOP_K=15
RAG_RRF_K=60

# Rerank：維持 MMR（不消耗 LLM 呼叫）
RAG_RERANK_METHOD=mmr
RAG_MMR_LAMBDA=0.6

# Multi-query：輕量模式關閉，減少 LLM 呼叫次數
RAG_MULTI_QUERY=0

# LLM 呼叫預算（輕量模式降低上限）
RAG_MAX_LLM_CALLS=6             # 標準是 12

# AI 自檢：預設關閉（節省 1 次 LLM 呼叫）
CONTRACT_RISK_SELF_CHECK_ENABLED=0

# --- BM25 中文分詞（jieba）---
BM25_TOKENIZER=jieba
# BM25_JIEBA_USERDICT=data/legal_terms.txt   # 自訂法律術語辭典（選填）

# --- Ollama 預拉模型指令（第一次部署時執行）---
# ollama pull gemma3:4b-it-qat
# ollama pull gemma3:12b
# ollama pull snowflake-arctic-embed2:568m
