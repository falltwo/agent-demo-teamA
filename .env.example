PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=weck06
# TEAM RULES:
# 1) Shared environment uses PINECONE_INDEX=weck06. Do not change without maintainer approval.
# 2) If you need temporary experiments, use your local untracked .env only.
# 3) Never commit personal/experimental index names to shared baseline files.

# Chat provider: gemini (default), ollama, local(=ollama)
CHAT_PROVIDER=gemini

# Gemini chat (used when CHAT_PROVIDER=gemini)
GOOGLE_API_KEY=your_google_api_key
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite-preview

# Ollama chat (used when CHAT_PROVIDER=ollama/local)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_API_KEY=ollama
OLLAMA_TIMEOUT_SEC=120
OLLAMA_CHAT_MODEL=gemma3:27b

# Auto model routing (backend chooses these stages; users do not select models in UI)
# Recommended for DGX low-latency profile:
# OLLAMA_ROUTER_MODEL=gemma3:4b-it-qat
# OLLAMA_RAG_REWRITE_MODEL=gemma3:4b-it-qat
# OLLAMA_RAG_RERANK_MODEL=gemma3:4b-it-qat
# OLLAMA_RAG_PACKAGE_MODEL=gemma3:4b-it-qat
# OLLAMA_RAG_GENERATE_MODEL=gemma3:27b
# OLLAMA_RESEARCH_GENERATE_MODEL=gemma3:27b
# OLLAMA_ANALYSIS_MODEL=gemma3:27b
# OLLAMA_CONTRACT_RISK_GENERATE_MODEL=gemma3:27b
# OLLAMA_CONTRACT_RISK_VERIFY_MODEL=gpt-oss:120b

# Optional stage timeouts (seconds). Keep cheap stages short to avoid long "no response" waits.
# OLLAMA_ROUTER_TIMEOUT_SEC=20
# OLLAMA_RAG_REWRITE_TIMEOUT_SEC=20
# OLLAMA_RAG_RERANK_TIMEOUT_SEC=25
# OLLAMA_RAG_PACKAGE_TIMEOUT_SEC=35
# OLLAMA_RAG_GENERATE_TIMEOUT_SEC=120
# OLLAMA_RESEARCH_GENERATE_TIMEOUT_SEC=120
# OLLAMA_ANALYSIS_TIMEOUT_SEC=120
# OLLAMA_CONTRACT_RISK_GENERATE_TIMEOUT_SEC=120
# OLLAMA_CONTRACT_RISK_VERIFY_TIMEOUT_SEC=180

# Embedding 設定
# EMBEDDING_PROVIDER 可選：gemini（預設）、ollama
EMBEDDING_PROVIDER=gemini
GEMINI_EMBED_MODEL=gemini-embedding-001
OLLAMA_EMBED_MODEL=snowflake-arctic-embed2:568m

# 網路搜尋（Tavily）

TAVILY_API_KEY=your_tavily_api_key

# Firecrawl（網頁擷取 / 搜尋 / 爬站）
# 取得 API key: https://firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_api_key


# 可選：用 output_dimensionality 降維，需與 Pinecone index 維度一致
# （如果不填，程式會自動讀取 index 維度來對齊）
# EMBED_DIM=1024

# 資料夾與檢索參數
RAG_DATA_DIR=data
TOP_K=5

# RAG 記憶與檢索（合約／法遵審閱建議開啟）
RAG_USE_HISTORY_FOR_QUERY=1
RAG_MAX_HISTORY_TURNS=12

# 多查詢檢索：主問句 + 輔助問句合併，補足交叉比對（如管轄法院 + 雙方地址）
# RAG_MULTI_QUERY=1
# RAG_AUX_QUERY_TOP_K=8
# RAG_AUX_QUERY_MAX=3

# Hybrid 檢索（向量 + BM25）：法條／合約條號與術語精準匹配，建議合約場景開啟
# RAG_USE_BM25=1
# RAG_BM25_TOP_K=20
# RAG_RRF_K=60
# BM25_CORPUS_PATH=bm25_corpus.json
# BM25 分詞器：jieba（預設，中文詞級）/ char（舊版，以空白切分）
# BM25_TOKENIZER=jieba
# 可選：外部 jieba 自訂辭典（每行一個詞，或 `詞 頻次 詞性`）；內建已載入常見合約/法律術語
# BM25_JIEBA_USERDICT=/path/to/userdict.txt

# Aux query 並行度（當 RAG_MULTI_QUERY=1 時 embedding+search 並行執行）
# RAG_AUX_QUERY_CONCURRENCY=4
# Rerank 方法：mmr（預設，免費快）/ llm（品質優先，每次 query 多 1 次 LLM 調用）/ none
# RAG_RERANK_METHOD=mmr
# MMR 的 λ（0~1，越高越偏相關性、越低越偏多樣性）
# RAG_MMR_LAMBDA=0.6

# 合約+法條路徑的 AI 自檢層（多 1 次 LLM 調用，約 +5-10 秒延遲）
# 預設關閉；需要嚴格品檢時設為 1
# CONTRACT_RISK_SELF_CHECK_ENABLED=0

#圖表
USE_ECHARTS_MCP=1




#uv run python eval/run_eval.py --groq
#Eval 運行記錄
EVAL_LOG_ENABLED=1
#Eval 運行記錄路徑
EVAL_LOG_PATH=eval_runs.jsonl


GROQ_API_KEY=your_groq_api_key

# CiteCheck（引文檢查，可選；未設定則不呼叫）
# CITECHECK_API_KEY=
# CITECHECK_BASE_URL=https://api.citecheck.ai
# CITECHECK_VERIFY_PATH=/api/verify

# Gavel / Documate（合約生成）
# 實際使用時請改成你自己的 workspace 參數與 API key
GAVEL_API_KEY=your_gavel_api_key
GAVEL_BASE_URL=https://api.gavel.io
# 如 Gavel 文件有指定自訂路徑，可在此覆寫，例如 /api/v1/documents
GAVEL_GENERATE_PATH=/api/documents

# FastAPI（與 Vue 本機開發；CORS 逗號分隔）
# API_HOST=0.0.0.0
# API_PORT=8000
# API_TITLE=agent-demo API
# API_VERSION=1.0.0
# API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# API_CORS_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1|192\\.168\\.[0-9]+\\.[0-9]+|100\\.[0-9]+\\.[0-9]+\\.[0-9]+)(:[0-9]+)?$

# 上傳灌入（FastAPI multipart）
# INGEST_MAX_FILE_MB=32
# INGEST_MAX_TOTAL_MB=128
# INGEST_MAX_FILES=20
# INGEST_TEMP_DIR=

